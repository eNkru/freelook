{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Freelook",
  "version": "2.0.0",
  "identifier": "nz.co.enkru.freelook",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "splash",
        "title": "Freelook",
        "width": 300,
        "height": 300,
        "decorations": false,
        "visible": true,
        "url": "view/splash.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": ["appimage", "deb", "rpm", "dmg", "msi"],
    "category": "public.app-category.productivity",
    "resources": [
      "../assets/outlook_macOS.png",
      "../assets/outlook_macOS_unread.png",
      "../assets/outlook_linux_unread.png"
    ]
  }
}
